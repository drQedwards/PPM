{\n "nbformat": 4,\n "nbformat_minor": 5,\n "metadata": {\n  "kernelspec": {\n   "display_name": "Python 3",\n   "language": "python",\n   "name": "python3"\n  },\n  "language_info": {\n   "name": "python",\n   "version": "3.12.0"\n  }\n },\n "cells": [\n  {\n   "cell_type": "markdown",\n   "id": "a1b2c3d4",\n   "metadata": {},\n   "source": [\n    "# ARC-AGI-3 CNN Agent (Improved)\n",\n    "\n",\n    "This notebook contains the improved `MyAgent` for the ARC-Prize 2026 competition.\n",\n    "\n",\n    "### Fixes applied vs original:\n",\n    "| # | Issue | Fix |\n",\n    "|---|-------|-----|\n",\n    "| 1 | `frames` list replacement may break base class ref | Use `deque(maxlen=N)` |\n",\n    "| 2 | `coord_probs_scaled / 4096` killed ACTION6 sampling | Normalize by sum, not count |\n",\n    "| 3 | No guard for empty/malformed frames | Added early return in `_frame_to_tensor` |\n",\n    "| 4 | Hash set never pruned → experiences permanently blacklisted | Removed hash set |\n",\n    "| 5 | `action_model=None` until first score change | Model initialized in `__init__` |\n",\n    "| 6 | Entropy term used wrong formula | Uses `-(p * log p).sum()` |\n",\n    "| 7 | `cuda.empty_cache()` every training step | Removed |\n",\n    "| 8 | `import json` inside hot loop | Moved to top-level |"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "id": "b2c3d4e5",\n   "metadata": {},\n   "source": [\n    "## Cell 1 — Install competition packages (offline wheels only)"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "id": "c3d4e5f6",\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "!pip install --no-index --find-links \\n",\n    "    /kaggle/input/competitions/arc-prize-2026-arc-agi-3/arc_agi_3_wheels \\n",\n    "    arc-agi python-dotenv"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "id": "d4e5f6a7",\n   "metadata": {},\n   "source": [\n    "## Cell 2 — Write the improved agent"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "id": "e5f6a7b8",\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "%%writefile /kaggle/working/my_agent.py\n",\n    "# =====================================================================\n",\n    "# ARC-AGI-3 CNN Agent — Improved (all fixes from code review applied)\n",\n    "# =====================================================================\n",\n    "import hashlib\n",\n    "import json\n",\n    "import logging\n",\n    "import os\n",\n    "import random\n",\n    "import time\n",\n    "import traceback\n",\n    "from collections import deque\n",\n    "from datetime import datetime\n",\n    "from typing import Any\n",\n    "\n",\n    "import numpy as np\n",\n    "import torch\n",\n    "import torch.nn as nn\n",\n    "import torch.nn.functional as F\n",\n    "import torch.optim as optim\n",\n    "\n",\n    "from agents.agent import Agent\n",\n    "from arcengine import FrameData, GameAction, GameState\n",\n    "\n",\n    "# ---------------------------------------------------------------------------\n",\n    "# Utilities\n",\n    "# ---------------------------------------------------------------------------\n",\n    "\n",\n    "def setup_experiment_directory(base_output_dir='runs'):\n",\n    "    \"\"\"Create directories for outputs and logging.\"\"\"\n",\n    "    timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",\n    "    base_dir = os.path.join(base_output_dir, timestamp)\n",\n    "    os.makedirs(base_dir, exist_ok=True)\n",\n    "    log_file = os.path.join(base_dir, 'logs.log')\n",\n    "    print(f\"Experiment directory created: {base_dir}\")\n",\n    "    return base_dir, log_file\n",\n    "\n",\n    "def get_environment_directory(base_dir, game_id):\n",\n    "    \"\"\"Get or create environment-specific directory for a game_id.\"\"\"\n",\n    "    env_dir = os.path.join(base_dir, game_id)\n",\n    "    os.makedirs(env_dir, exist_ok=True)\n",\n    "    return env_dir\n",\n    "\n",\n    "def setup_logging_for_experiment(log_file_path):\n",\n    "    \"\"\"Update logging configuration to use the experiment directory's log file.\"\"\"\n",\n    "    root_logger = logging.getLogger()\n",\n    "    for handler in root_logger.handlers[:]:\n",\n    "        if isinstance(handler, logging.FileHandler):\n",\n    "            root_logger.removeHandler(handler)\n",\n    "            handler.close()\n",\n    "    formatter = logging.Formatter(\"%(asctime)s | %(levelname)s | %(message)s\")\n",\n    "    file_handler = logging.FileHandler(log_file_path, mode=\"w\")\n",\n    "    file_handler.setLevel(root_logger.level)\n",\n    "    file_handler.setFormatter(formatter)\n",\n    "    root_logger.addHandler(file_handler)\n",\n    "\n",\n    "# ---------------------------------------------------------------------------\n",\n    "# ActionModel CNN\n",\n    "# ---------------------------------------------------------------------------\n",\n    "\n",\n    "class ActionModel(nn.Module):\n",\n    "    \"\"\"CNN that predicts which actions will result in new frames.\n",\n    "    \n",\n    "    Output shape: [batch, 5 + grid_size*grid_size]\n",\n    "      - Indices 0-4  : ACTION1-ACTION5 logits\n",\n    "      - Indices 5+   : ACTION6 coordinate logits (flattened HxW)\n",\n    "    \"\"\"\n",\n    "\n",\n    "    def __init__(self, input_channels: int = 16, grid_size: int = 64):\n",\n    "        super().__init__()\n",\n    "        self.grid_size = grid_size\n",\n    "        self.num_action_types = 5\n",\n    "\n",\n    "        # Shared convolutional backbone\n",\n    "        self.conv1 = nn.Conv2d(input_channels, 32, kernel_size=3, padding=1)\n",\n    "        self.conv2 = nn.Conv2d(32, 64, kernel_size=3, padding=1)\n",\n    "        self.conv3 = nn.Conv2d(64, 128, kernel_size=3, padding=1)\n",\n    "        self.conv4 = nn.Conv2d(128, 256, kernel_size=3, padding=1)\n",\n    "\n",\n    "        # ACTION1-5 head\n",\n    "        self.action_pool = nn.MaxPool2d(4, 4)\n",\n    "        action_flattened_size = 256 * 16 * 16\n",\n    "        self.action_fc = nn.Linear(action_flattened_size, 512)\n",\n    "        self.action_head = nn.Linear(512, self.num_action_types)\n",\n    "\n",\n    "        # ACTION6 coordinate head (grid_size x grid_size)\n",\n    "        self.coord_conv1 = nn.Conv2d(256, 128, kernel_size=3, padding=1)\n",\n    "        self.coord_conv2 = nn.Conv2d(128, 64, kernel_size=3, padding=1)\n",\n    "        self.coord_conv3 = nn.Conv2d(64, 32, kernel_size=1)\n",\n    "        self.coord_conv4 = nn.Conv2d(32, 1, kernel_size=1)\n",\n    "\n",\n    "        self.dropout = nn.Dropout(0.2)\n",\n    "\n",\n    "    def forward(self, x: torch.Tensor) -> torch.Tensor:\n",\n    "        x = F.relu(self.conv1(x))\n",\n    "        x = F.relu(self.conv2(x))\n",\n    "        x = F.relu(self.conv3(x))\n",\n    "        conv_features = F.relu(self.conv4(x))\n",\n    "\n",\n    "        # --- ACTION1-5 head ---\n",\n    "        action_features = self.action_pool(conv_features)\n",\n    "        action_features = action_features.view(action_features.size(0), -1)\n",\n    "        action_features = F.relu(self.action_fc(action_features))\n",\n    "        action_features = self.dropout(action_features)\n",\n    "        action_logits = self.action_head(action_features)          # [B, 5]\n",\n    "\n",\n    "        # --- ACTION6 coordinate head ---\n",\n    "        coord_features = F.relu(self.coord_conv1(conv_features))\n",\n    "        coord_features = F.relu(self.coord_conv2(coord_features))\n",\n    "        coord_features = F.relu(self.coord_conv3(coord_features))\n",\n    "        coord_logits = self.coord_conv4(coord_features)            # [B, 1, H, W]\n",\n    "        coord_logits = coord_logits.view(coord_logits.size(0), -1) # [B, H*W]\n",\n    "\n",\n    "        return torch.cat([action_logits, coord_logits], dim=1)     # [B, 5+H*W]\n",\n    "\n",\n    "# ---------------------------------------------------------------------------\n",\n    "# MyAgent\n",\n    "# ---------------------------------------------------------------------------\n",\n    "\n",\n    "class MyAgent(Agent):\n",\n    "    \"\"\"CNN-based action-learning agent for ARC-AGI-3.\n",\n    "    \n",\n    "    Learns which actions cause observable frame changes and preferentially\n",\n    "    samples those actions using a binary-reward signal.\n",\n    "    \"\"\"\n",\n    "\n",\n    "    MAX_ACTIONS = float('inf')\n",\n    "    _MAX_FRAMES = 10  # sliding window kept in self.frames\n",\n    "\n",\n    "    def __init__(self, *args: Any, **kwargs: Any) -> None:\n",\n    "        super().__init__(*args, **kwargs)\n",\n    "\n",\n    "        # Reproducible but game-specific seeding\n",\n    "        seed = int(time.time() * 1_000_000) + hash(self.game_id) % 1_000_000\n",\n    "        random.seed(seed)\n",\n    "        np.random.seed(seed % (2**32 - 1))\n",\n    "        torch.manual_seed(seed % (2**32 - 1))\n",\n    "        self.start_time = time.time()\n",\n    "\n",\n    "        self.device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",\n    "        print(f\"Action agent using device: {self.device}\")\n",\n    "\n",\n    "        # FIX #1 — replace base-class frames list with a capped deque so\n",\n    "        # append_frame no longer needs to create a new list each call.\n",\n    "        self.frames = deque(maxlen=self._MAX_FRAMES)\n",\n    "\n",\n    "        # Experiment / logging setup\n",\n    "        self.base_dir, log_file = setup_experiment_directory()\n",\n    "        setup_logging_for_experiment(log_file)\n",\n    "        env_dir = get_environment_directory(self.base_dir, self.game_id)\n",\n    "        self.log_dir = env_dir\n",\n    "        self.logger = logging.getLogger(f\"ActionAgent_{self.game_id}\")\n",\n    "        self.logger.info(f\"Agent initialised for game_id: {self.game_id}\")\n",\n    "\n",\n    "        self.current_score = -1\n",\n    "        self.save_action_visualizations = False  # disabled for submission\n",\n    "\n",\n    "        # Grid / colour constants\n",\n    "        self.grid_size = 64\n",\n    "        self.num_coordinates = self.grid_size * self.grid_size\n",\n    "        self.num_colours = 16\n",\n    "\n",\n    "        # FIX #5 — initialise model eagerly so the first call to choose_action\n",\n    "        # never hits a None model regardless of score value.\n",\n    "        self.action_model = ActionModel(\n",\n    "            input_channels=self.num_colours, grid_size=self.grid_size\n",\n    "        ).to(self.device)\n",\n    "        self.optimizer = optim.Adam(self.action_model.parameters(), lr=0.0001)\n",\n    "\n",\n    "        # Experience replay — FIX #4: no separate hash set; deque maxlen is enough.\n",\n    "        self.experience_buffer: deque = deque(maxlen=200_000)\n",\n    "        self.batch_size = 64\n",\n    "        self.train_frequency = 5\n",\n    "\n",\n    "        # State tracking\n",\n    "        self.prev_frame: np.ndarray | None = None\n",\n    "        self.prev_action_idx: int | None = None\n",\n    "\n",\n    "        # Ordered list of discrete actions\n",\n    "        self.action_list = [\n",\n    "            GameAction.ACTION1, GameAction.ACTION2, GameAction.ACTION3,\n",\n    "            GameAction.ACTION4, GameAction.ACTION5,\n",\n    "        ]\n",\n    "    # ------------------------------------------------------------------\n",\n    "    # Frame management\n",\n    "    # ------------------------------------------------------------------\n",\n    "\n",\n    "    def append_frame(self, frame: FrameData) -> None:\n",\n    "        \"\"\"Append a frame; the deque's maxlen handles the sliding window cap.\n",\n    "\n",\n    "        FIX #1 — no more list-slice reassignment.\n",\n    "        FIX #8 — json imported at module level.\n",\n    "        \"\"\"\n",\n    "        self.frames.append(frame)\n",\n    "        if frame.guid:\n",\n    "            self.guid = frame.guid\n",\n    "        if hasattr(self, \"recorder\") and not self.is_playback:\n",\n    "            self.recorder.record(json.loads(frame.model_dump_json()))\n",\n    "\n",\n    "    # ------------------------------------------------------------------\n",\n    "    # Internal helpers\n",\n    "    # ------------------------------------------------------------------\n",\n    "\n",\n    "    def _get_score(self, frame: FrameData) -> int:\n",\n    "        \"\"\"Return score, falling back to levels_completed.\"\"\"\n",\n    "        return getattr(frame, 'score', None) or frame.levels_completed\n",\n    "\n",\n    "    def _frame_to_tensor(self, frame_data: FrameData) -> torch.Tensor | None:\n",\n    "        \"\"\"Convert a FrameData object to a one-hot [C, H, W] float tensor.\n",\n    "\n",\n    "        FIX #3 — guard against empty / malformed frame payloads.\n",\n    "        \"\"\"\n",\n    "        if not frame_data.frame:\n",\n    "            return None\n",\n    "        frame_arr = np.array(frame_data.frame, dtype=np.int64)\n",\n    "        if frame_arr.ndim == 3:\n",\n    "            frame_arr = frame_arr[-1]          # take the most recent slice\n",\n    "        if frame_arr.ndim != 2 or frame_arr.shape != (self.grid_size, self.grid_size):\n",\n    "            return None\n",\n    "        tensor = torch.zeros(\n",\n    "            self.num_colours, self.grid_size, self.grid_size, dtype=torch.float32\n",\n    "        )\n",\n    "        tensor.scatter_(0, torch.from_numpy(frame_arr).unsqueeze(0), 1)\n",\n    "        return tensor.to(self.device)\n",\n    "\n",\n    "    def _sample_from_combined_output(\n",\n    "        self,\n",\n    "        combined_logits: torch.Tensor,\n",\n    "        available_actions=None,\n",\n    "    ):\n",\n    "        \"\"\"Sample an action from the joint 5 + H*W action space.\n",\n    "\n",\n    "        FIX #2 — coordinate probabilities are re-normalised so their *total*\n",\n    "        weight equals the total weight of ACTION1-5, giving ACTION6 a fair\n",\n    "        chance when it produces the highest individual coordinate probability.\n",\n    "        \"\"\"\n",\n    "        action_logits = combined_logits[:5]\n",\n    "        coord_logits  = combined_logits[5:]\n",\n    "\n",\n    "        # --- availability masking ---\n",\n    "        if available_actions is not None and len(available_actions) > 0:\n",\n    "            action_mask = torch.full_like(action_logits, float('-inf'))\n",\n    "            action6_available = False\n",\n    "            for action in available_actions:\n",\n    "                action_id = action.value if hasattr(action, 'value') else int(action)\n",\n    "                if 1 <= action_id <= 5:\n",\n    "                    action_mask[action_id - 1] = 0.0\n",\n    "                elif action_id == 6:\n",\n    "                    action6_available = True\n",\n    "            action_logits = action_logits + action_mask\n",\n    "            if not action6_available:\n",\n    "                coord_logits = coord_logits + torch.full_like(coord_logits, float('-inf'))\n",\n    "\n",\n    "        action_probs = torch.sigmoid(action_logits)   # [5]\n",\n    "        coord_probs  = torch.sigmoid(coord_logits)    # [H*W]\n",\n    "\n",\n    "        # FIX #2: scale coord space so its total probability mass equals\n",\n    "        # the total probability mass of the action space.\n",\n    "        coord_sum  = coord_probs.sum()\n",\n    "        action_sum = action_probs.sum()\n",\n    "        if coord_sum > 1e-8:\n",\n    "            coord_probs_scaled = coord_probs / coord_sum * action_sum\n",\n    "        else:\n",\n    "            coord_probs_scaled = coord_probs\n",\n    "\n",\n    "        all_probs = torch.cat([action_probs, coord_probs_scaled])\n",\n    "        total = all_probs.sum()\n",\n    "        if total < 1e-8:   # safety: uniform fallback\n",\n    "            all_probs = torch.ones_like(all_probs)\n",\n    "            total = all_probs.sum()\n",\n    "        all_probs_np = (all_probs / total).cpu().numpy()\n",\n    "\n",\n    "        selected_idx = int(np.random.choice(len(all_probs_np), p=all_probs_np))\n",\n    "\n",\n    "        # Visualisation probabilities (unscaled coord space for display)\n",\n    "        all_probs_viz = torch.cat([action_probs, coord_probs]).cpu().numpy()\n",\n    "\n",\n    "        if selected_idx < 5:\n",\n    "            return selected_idx, None, None, all_probs_viz\n",\n    "        coord_idx = selected_idx - 5\n",\n    "        y_idx = coord_idx // self.grid_size\n",\n    "        x_idx = coord_idx %  self.grid_size\n",\n    "        return 5, (y_idx, x_idx), coord_idx, all_probs_viz\n",\n    "\n",\n    "    def _train_action_model(self) -> None:\n",\n    "        \"\"\"Sample a mini-batch from the replay buffer and perform one gradient step.\n",\n    "\n",\n    "        FIX #6 — proper entropy regularisation using -sum(p * log p).\n",\n    "        FIX #7 — cuda.empty_cache() removed (hurts throughput, not needed).\n",\n    "        \"\"\"\n",\n    "        if len(self.experience_buffer) < self.batch_size:\n",\n    "            return\n",\n    "\n",\n    "        indices = np.random.choice(len(self.experience_buffer), self.batch_size, replace=False)\n",\n    "        batch   = [self.experience_buffer[i] for i in indices]\n",\n    "\n",\n    "        states  = torch.stack(\n",\n    "            [torch.from_numpy(exp['state']).float().to(self.device) for exp in batch]\n",\n    "        )\n",\n    "        action_indices = torch.tensor(\n",\n    "            [exp['action_idx'] for exp in batch], dtype=torch.long, device=self.device\n",\n    "        )\n",\n    "        rewards = torch.tensor(\n",\n    "            [exp['reward'] for exp in batch], dtype=torch.float32, device=self.device\n",\n    "        )\n",\n    "\n",\n    "        self.optimizer.zero_grad()\n",\n    "\n",\n    "        combined_logits = self.action_model(states)                 # [B, 5+H*W]\n",\n    "        selected_logits = combined_logits.gather(\n",\n    "            1, action_indices.unsqueeze(1)\n",\n    "        ).squeeze(1)                                                # [B]\n",\n    "        main_loss = F.binary_cross_entropy_with_logits(selected_logits, rewards)\n",\n    "\n",\n    "        # FIX #6 — correct entropy: H = -sum(p * log p) for the action head only\n",\n    "        action_probs = torch.softmax(combined_logits[:, :5], dim=1)  # [B, 5]\n",\n    "        action_entropy = -(action_probs * torch.log(action_probs + 1e-8)).sum(dim=1).mean()\n",\n    "\n",\n    "        total_loss = main_loss - 0.001 * action_entropy\n",\n    "        total_loss.backward()\n",\n    "        self.optimizer.step()\n",\n    "        # NOTE: cuda.empty_cache() intentionally removed (FIX #7)\n",\n    "    def _reset_for_new_level(self, new_score: int) -> None:\n",\n    "        \"\"\"Clear replay buffer and reinitialise model when advancing a level.\"\"\"\n",\n    "        self.logger.info(\n",\n    "            f\"Score changed {self.current_score} → {new_score} \"\n",\n    "            f\"at action {self.action_counter}\"\n",\n    "        )\n",\n    "        print(f\"Score changed {self.current_score} → {new_score} at action {self.action_counter}\")\n",\n    "\n",\n    "        self.experience_buffer.clear()\n",\n    "        self.action_model = ActionModel(\n",\n    "            input_channels=self.num_colours, grid_size=self.grid_size\n",\n    "        ).to(self.device)\n",\n    "        self.optimizer = optim.Adam(self.action_model.parameters(), lr=0.0001)\n",\n    "        self.prev_frame = None\n",\n    "        self.prev_action_idx = None\n",\n    "        self.current_score = new_score\n",\n    "        print(\"Reset experience buffer and model for new level.\")\n",\n    "\n",\n    "    def _has_time_elapsed(self) -> bool:\n",\n    "        \"\"\"Return True if within 5 minutes of the 8-hour wall clock limit.\"\"\"\n",\n    "        return (time.time() - self.start_time) >= 8 * 3600 - 5 * 60\n",\n    "    # ------------------------------------------------------------------\n",\n    "    # Agent interface\n",\n    "    # ------------------------------------------------------------------\n",\n    "\n",\n    "    def is_done(self, frames, latest_frame: FrameData) -> bool:\n",\n    "        \"\"\"Signal the harness to stop calling choose_action.\"\"\"\n",\n    "        try:\n",\n    "            return latest_frame.state is GameState.WIN or self._has_time_elapsed()\n",\n    "        except Exception as e:\n",\n    "            print(f\"[is_done] error: {e}\")\n",\n    "            traceback.print_exc()\n",\n    "            return True\n",\n    "\n",\n    "    def choose_action(self, frames, latest_frame: FrameData) -> GameAction:\n",\n    "        \"\"\"Select the next action using the CNN's predicted frame-change probability.\"\"\"\n",\n    "        try:\n",\n    "            # --- debug logging on first step ---\n",\n    "            if self.action_counter == 0:\n",\n    "                print(f\"[DEBUG] frame type: {type(latest_frame)}\")\n",\n    "                print(f\"[DEBUG] state: {latest_frame.state}\")\n",\n    "                print(f\"[DEBUG] levels_completed: {latest_frame.levels_completed}\")\n",\n    "                print(f\"[DEBUG] has score attr: {hasattr(latest_frame, 'score')}\")\n",\n    "                print(f\"[DEBUG] available_actions: {getattr(latest_frame, 'available_actions', 'N/A')}\")\n",\n    "                if hasattr(latest_frame, 'frame') and latest_frame.frame:\n",\n    "                    print(f\"[DEBUG] frame shape: {np.array(latest_frame.frame).shape}\")\n",\n    "\n",\n    "            # --- level transition detection ---\n",\n    "            current_level = self._get_score(latest_frame)\n",\n    "            if current_level != self.current_score:\n",\n    "                self._reset_for_new_level(current_level)\n",\n    "\n",\n    "            # --- handle terminal / unstarted states ---\n",\n    "            if latest_frame.state in (GameState.NOT_PLAYED, GameState.GAME_OVER):\n",\n    "                self.prev_frame = None\n",\n    "                self.prev_action_idx = None\n",\n    "                action = GameAction.RESET\n",\n    "                action.reasoning = \"Game needs reset.\"\n",\n    "                return action\n",\n    "\n",\n    "            # --- encode current frame ---\n",\n    "            current_tensor = self._frame_to_tensor(latest_frame)\n",\n    "            if current_tensor is None:\n",\n    "                self.prev_frame = None\n",\n    "                self.prev_action_idx = None\n",\n    "                action = random.choice(self.action_list)\n",\n    "                action.reasoning = f\"Fallback random (bad frame): {action.value}\"\n",\n    "                return action\n",\n    "\n",\n    "            # --- store experience from the previous step ---\n",\n    "            if self.prev_frame is not None and self.prev_action_idx is not None:\n",\n    "                current_bool = current_tensor.cpu().numpy().astype(bool)\n",\n    "                frame_changed = not np.array_equal(self.prev_frame, current_bool)\n",\n    "                # FIX #4 — no hash set; just append to the deque.\n",\n    "                self.experience_buffer.append({\n",\n    "                    'state': self.prev_frame,\n",\n    "                    'action_idx': self.prev_action_idx,\n",\n    "                    'reward': 1.0 if frame_changed else 0.0,\n",\n    "                })\n",\n    "\n",\n    "            # --- forward pass ---\n",\n    "            available_actions = getattr(latest_frame, 'available_actions', None)\n",\n    "            with torch.no_grad():\n",\n    "                logits = self.action_model(current_tensor.unsqueeze(0)).squeeze(0)\n",\n    "            action_idx, coords, coord_idx, all_probs = self._sample_from_combined_output(\n",\n    "                logits, available_actions\n",\n    "            )\n",\n    "\n",\n    "            # --- decode action ---\n",\n    "            if action_idx < 5:\n",\n    "                selected_action = self.action_list[action_idx]\n",\n    "                selected_action.reasoning = (\n",\n    "                    f\"{selected_action.name} (prob: {all_probs[action_idx]:.3f})\"\n",\n    "                )\n",\n    "                self.prev_action_idx = action_idx\n",\n    "            else:\n",\n    "                y, x = coords\n",\n    "                selected_action = GameAction.ACTION6\n",\n    "                selected_action.set_data({\"x\": int(x), \"y\": int(y)})\n",\n    "                selected_action.reasoning = (\n",\n    "                    f\"ACTION6 at ({x},{y}) (prob: {all_probs[5 + coord_idx]:.3f})\"\n",\n    "                )\n",\n    "                self.prev_action_idx = 5 + coord_idx\n",\n    "\n",\n    "            # FIX #6 bounds assertion (development aid — disable for speed if needed)\n",\n    "            assert 0 <= self.prev_action_idx < 5 + self.num_coordinates, (\n",\n    "                f\"prev_action_idx out of range: {self.prev_action_idx}\"\n",\n    "            )\n",\n    "\n",\n    "            self.prev_frame = current_tensor.cpu().numpy().astype(bool)\n",\n    "\n",\n    "            # --- periodic training ---\n",\n    "            if self.action_counter % self.train_frequency == 0:\n",\n    "                self._train_action_model()\n",\n    "\n",\n    "            return selected_action\n",\n    "\n",\n    "        except Exception as e:\n",\n    "            print(f\"[choose_action] CRASH at step {self.action_counter}: {type(e).__name__}: {e}\")\n",\n    "            traceback.print_exc()\n",\n    "            action = random.choice(self.action_list)\n",\n    "            action.reasoning = f\"Fallback after crash: {e}\"\n",\n    "            return action"\n   ]\n  },\n  {\n   "cell_type": "markdown",\n   "id": "f6a7b8c9",\n   "metadata": {},\n   "source": [\n    "## Cell 3 — Non-competition dummy submission (local/validation runs)"\n   ]\n  },\n  {\n   "cell_type": "code",\n   "execution_count": null,\n   "id": "a7b8c9d0",\n   "metadata": {},\n   "outputs": [],\n   "source": [\n    "import os\n",\n    "if not os.getenv('KAGGLE_IS_COMPETITION_RERUN'):\n",\n    "    import pandas as pd\n",\n    "    submission = pd.DataFrame(\n",\n    "        data=[['1_0', '1', True, 1]],\n",\n    "        columns=['row_id', 'game_id', 'end_of_game', 'score'],\n",\n    "    )\n",\n    "    submission.to_parquet('/kaggle/working/submission.parquet', index=False)\n",\n    "    submission.head()"\n   ]\n  }\n ]\n}